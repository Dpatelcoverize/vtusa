

 
# Disable directory browsing
Options -Indexes
 
# Allow access to files with valid paths
<FilesMatch ".*">
    Require all granted
</FilesMatch>
 
# Custom Error Pages
ErrorDocument 403 /page-error-403.html
ErrorDocument 404 /page-error-404.html
ErrorDocument 500 /page-error-500.html
 
# Rewrite rules to handle invalid file paths
RewriteEngine On
 
# Check if the requested file or directory exists
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
 